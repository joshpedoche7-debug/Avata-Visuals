let allBookings = [];

async function loadBookings() {
  const list = document.getElementById("bookingsList");
  list.innerHTML = '<div class="dashboard-loading">Loading bookings...</div>';
  try {
    const q = query(collection(db, "bookings"), orderBy("submittedAt", "desc"));
    const snapshot = await getDocs(q);
    allBookings = [];
    snapshot.forEach(d => allBookings.push({ id: d.id, ...d.data() }));
    renderBookings(allBookings);
  } catch (err) {
    list.innerHTML = '<div class="dashboard-loading">Could not load bookings.</div>';
    console.error(err);
  }
}

function statusActionsHTML(docId, currentStatus) {
  const statuses = ["pending", "confirmed", "cancelled"];
  return `
    <div class="status-actions" data-id="${docId}">
      ${statuses.map(s => `
        <button
          class="status-btn ${s}${currentStatus === s ? " active" : ""}"
          data-id="${docId}"
          data-status="${s}"
          ${currentStatus === s ? "disabled" : ""}
        >${s.charAt(0).toUpperCase() + s.slice(1)}</button>
      `).join("")}
    </div>`;
}

function updateCardStatusButtons(card, newStatus) {
  const actions = card.querySelector(".status-actions");
  if (!actions) return;
  actions.querySelectorAll(".status-btn").forEach(btn => {
    const isActive = btn.dataset.status === newStatus;
    btn.classList.toggle("active", isActive);
    btn.disabled = isActive;
  });
}

function renderBookings(bookings) {
  const list       = document.getElementById("bookingsList");
  const noBookings = document.getElementById("noBookings");
  if (bookings.length === 0) {
    list.innerHTML = "";
    noBookings.style.display = "block";
    return;
  }
  noBookings.style.display = "none";
  list.innerHTML = bookings.map(b => {
    const status = b.status || "pending";
    const date   = b.submittedAt
      ? new Date(b.submittedAt.seconds * 1000).toLocaleDateString("en-PH", { year:"numeric", month:"short", day:"numeric" })
      : "—";
    return `
    <div class="booking-card" id="card-${b.id}">
      <div class="booking-card-top">
        <div>
          <div class="booking-name">${b.name}</div>
          <div class="booking-id">${b.bookingId || b.id}</div>
        </div>
        ${statusActionsHTML(b.id, status)}
      </div>
      <div class="booking-grid">
        <div class="booking-field"><div class="booking-field-label">Email</div><div class="booking-field-value">${b.email}</div></div>
        <div class="booking-field"><div class="booking-field-label">Meeting Date</div><div class="booking-field-value">${b.date} at ${b.time}</div></div>
        <div class="booking-field"><div class="booking-field-label">Package</div><div class="booking-field-value">${b.package}</div></div>
        <div class="booking-field"><div class="booking-field-label">Submitted</div><div class="booking-field-value">${date}</div></div>
      </div>
      ${b.message ? `<div class="booking-message">💬 ${b.message}</div>` : ""}
      <div class="booking-actions">
        <button class="delete-booking-btn" data-id="${b.id}">Delete Booking</button>
      </div>
    </div>`;
  }).join("");
}

async function setStatus(docId, newStatus) {
  try {
    await updateDoc(doc(db, "bookings", docId), { status: newStatus });
    const booking = allBookings.find(b => b.id === docId);
    if (booking) booking.status = newStatus;
    const card = document.querySelector(`#card-${docId}`);
    if (card) updateCardStatusButtons(card, newStatus);
  } catch (err) {
    console.error("Status update error:", err);
    alert("Could not update status. Please try again.");
  }
}

function filterBookings() {
  const status = document.getElementById("filterStatus").value;
  const search = document.getElementById("filterSearch").value.toLowerCase();
  const filtered = allBookings.filter(b => {
    const matchStatus = status === "all" || (b.status || "pending") === status;
    const matchSearch = b.name.toLowerCase().includes(search) || b.email.toLowerCase().includes(search);
    return matchStatus && matchSearch;
  });
  renderBookings(filtered);
}

