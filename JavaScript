async function generateQR() {
  // Must be signed in to book
  if (!auth.currentUser) {
    showConfirm({
      icon: "🔐",
      title: "Sign In Required",
      message: "You need to sign in or create an account before booking a meeting.",
      yesLabel: "Sign In",
      onConfirm: () => openModal()
    });
    return;
  }

  const name    = document.getElementById("qrName").value.trim();
  const email   = document.getElementById("qrEmail").value.trim();
  const date    = document.getElementById("qrDate").value;
  const time    = document.getElementById("qrTime").value;
  const pkg     = document.getElementById("qrPackage").value;
  const message = document.getElementById("qrMessage").value.trim();

  if (!name || !email || !date) {
    alert("Please fill in your name, email, and preferred date.");
    return;
  }

  document.getElementById("spinnerOverlay").classList.add("active");

  const bookingId = "CEM-" + Date.now() + "-" + Math.random().toString(36).substr(2,5).toUpperCase();

  try {
    const q = query(collection(db, "bookings"), where("date", "==", date));
    const snapshot = await getDocs(q);
    let conflict = false;
    snapshot.forEach(d => {
      const data = d.data();
      if (data.status !== "cancelled") conflict = true;
    });
    if (conflict) {
      document.getElementById("spinnerOverlay").classList.remove("active");
      alert(`Sorry! ${date} is already fully booked. Please choose a different date.`);
      return;
    }
  } catch (err) {
    console.error("Double booking check error:", err);
  }

  const text = [
    "Avata Visuals — Appointment",
    "Booking ID: " + bookingId,
    "Name: " + name,
    "Email: " + email,
    "Date: " + date,
    "Time: " + time,
    "Package: " + pkg,
    message ? "Message: " + message : "",
    "Coordinator: eventsbymaryfatima@gmail.com"
  ].filter(Boolean).join("\n");

  const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${encodeURIComponent(text)}`;

  const bookingError = document.getElementById("bookingError");
  bookingError.style.display = "none";

  try {
    await addDoc(collection(db, "bookings"), {
      bookingId:   bookingId,
      name:        name,
      email:       email,
      userEmail:   auth.currentUser ? auth.currentUser.email : email,
      date:        date,
      time:        time,
      package:     pkg,
      message:     message || "",
      qrCode:      qrUrl,
      status:      "pending",
      submittedAt: serverTimestamp()
    });
    if (auth.currentUser && auth.currentUser.email !== COORDINATOR_EMAIL) {
      loadMyBookings(auth.currentUser.email);
    }
  } catch (err) {
    console.error("Firestore error:", err);
    alert("Something went wrong. Please try again.");
  }

  emailjs.send("service_7exp1s7", "template_47kx30c", {
    client_name:  name,
    client_email: email,
    meeting_date: date,
    meeting_time: time,
    package:      pkg,
    message:      message || "No additional message.",
    booking_id:   bookingId,
  })
  .then(() => {
    return emailjs.send("service_7exp1s7", "template_9x7ure9", {
      client_name:  name,
      client_email: email,
      meeting_date: date,
      meeting_time: time,
      package:      pkg,
      message:      message || "No additional message.",
      booking_id:   bookingId,
      to_email:     email
    });
  })
  .then(() => {
    document.getElementById("qrSuccess").style.display = "block";
  })
  .catch((err) => {
    console.error("EmailJS Error:", err);
  });

  const container = document.getElementById("qrCanvas");
  container.innerHTML = `<img src="${qrUrl}" width="200" height="200" alt="QR Code" style="display:block;">`;
  document.getElementById("qrOutput").style.display = "block";
  document.getElementById("spinnerOverlay").classList.remove("active");
}

