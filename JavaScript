function downloadQR() {
  const img = document.querySelector("#qrCanvas img");
  if (!img) return;
  fetch(img.src)
    .then(res => res.blob())
    .then(blob => {
      const url  = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.download = "cempron-appointment-qr.png";
      link.href = url;
      link.click();
      URL.revokeObjectURL(url);
    })
    .catch(() => window.open(img.src, "_blank"));
}

// =====================
// QR SCAN
// =====================
function scanQR(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (ev) => {
    const previewImg = document.getElementById("qrPreviewImg");
    previewImg.src = ev.target.result;
    document.getElementById("qrScanPreview").style.display = "block";
    document.getElementById("qrScanResult").style.display  = "none";
    document.getElementById("qrScanError").style.display   = "none";
    const image = new Image();
    image.onload = () => {
      const cvs = document.createElement("canvas");
      cvs.width = image.width; cvs.height = image.height;
      const ctx = cvs.getContext("2d");
      ctx.drawImage(image, 0, 0);
      const imageData = ctx.getImageData(0, 0, cvs.width, cvs.height);
      const code = jsQR(imageData.data, imageData.width, imageData.height);
      if (code) {
        document.getElementById("qrResultBox").textContent = code.data;
        document.getElementById("qrScanResult").style.display = "block";
      } else {
        document.getElementById("qrScanError").style.display = "block";
      }
    };
    image.src = ev.target.result;
  };
  reader.readAsDataURL(file);
}

// =====================
// MY BOOKINGS (client)
// =====================
async function loadMyBookings(userEmail) {
  const list  = document.getElementById("myBookingsList");
  const empty = document.getElementById("myBookingsEmpty");
  list.innerHTML = '<div class="dashboard-loading">Loading your bookings...</div>';
  try {
    const q = query(collection(db, "bookings"), where("userEmail", "==", userEmail));
    const snapshot = await getDocs(q);
    const bookings = [];
    snapshot.forEach(d => bookings.push({ id: d.id, ...d.data() }));
    bookings.sort((a, b) => {
      const ta = a.submittedAt ? a.submittedAt.seconds : 0;
      const tb = b.submittedAt ? b.submittedAt.seconds : 0;
      return tb - ta;
    });
    if (bookings.length === 0) {
      list.innerHTML = "";
      empty.style.display = "block";
      return;
    }
    empty.style.display = "none";
    list.innerHTML = bookings.map(b => {
      const status    = b.status || "pending";
      const canCancel = status !== "cancelled";
      return `
      <div class="booking-card" id="my-card-${b.id}">
        <div class="booking-card-top">
          <div>
            <div class="booking-name">${b.name}</div>
            <div class="booking-id">${b.bookingId || b.id}</div>
          </div>
          <span class="booking-status status-${status}">
            ${status.charAt(0).toUpperCase() + status.slice(1)}
          </span>
        </div>
        <div class="booking-grid">
          <div class="booking-field">
            <div class="booking-field-label">Meeting Date</div>
            <div class="booking-field-value">${b.date} at ${b.time}</div>
          </div>
          <div class="booking-field">
            <div class="booking-field-label">Package</div>
            <div class="booking-field-value">${b.package}</div>
          </div>
        </div>
        ${b.message ? `<div class="booking-message">💬 ${b.message}</div>` : ""}
        <div class="booking-actions">
          ${canCancel ? `<button class="cancel-booking-btn" data-id="${b.id}">Cancel Booking</button>` : ""}
          <button class="delete-booking-btn" data-id="${b.id}">Delete Booking</button>
        </div>
      </div>`;
    }).join("");
  } catch (err) {
    list.innerHTML = '<div class="dashboard-loading">Could not load bookings.</div>';
    console.error("loadMyBookings error:", err);
  }
}

