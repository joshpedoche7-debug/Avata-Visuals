function showConfirm({ icon = "⚠️", title, message, yesLabel = "Confirm", onConfirm }) {
  const overlay = document.getElementById("confirmOverlay");
  if (!overlay) {
    // Fallback if HTML not added yet
    if (window.confirm(message)) onConfirm();
    return;
  }
  document.getElementById("confirmIcon").textContent = icon;
  document.getElementById("confirmTitle").textContent = title;
  document.getElementById("confirmMessage").textContent = message;

  overlay.classList.add("active");

  // Clone to remove any previous listeners
  const yesBtn = document.getElementById("confirmYesBtn");
  const noBtn  = document.getElementById("confirmNoBtn");
  const newYes = yesBtn.cloneNode(true);
  const newNo  = noBtn.cloneNode(true);
  newYes.textContent = yesLabel;
  yesBtn.replaceWith(newYes);
  noBtn.replaceWith(newNo);

  function close() { overlay.classList.remove("active"); }

  document.getElementById("confirmYesBtn").addEventListener("click", () => { close(); onConfirm(); });
  document.getElementById("confirmNoBtn").addEventListener("click", close);
  overlay.addEventListener("click", (e) => { if (e.target === overlay) close(); }, { once: true });
}

