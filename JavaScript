function cancelMyBooking(docId) {
  showConfirm({
    icon:     "🚫",
    title:    "Cancel Booking?",
    message:  "Are you sure you want to cancel this booking? This cannot be undone.",
    yesLabel: "Yes, Cancel",
    onConfirm: async () => {
      try {
