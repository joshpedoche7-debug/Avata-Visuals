function deleteBooking(docId) {
  showConfirm({
    icon:     "🗑️",
    title:    "Delete Booking?",
    message:  "This will permanently delete the booking and cannot be recovered.",
    yesLabel: "Yes, Delete",
    onConfirm: async () => {
      try {
        await deleteDoc(doc(db, "bookings", docId));
        if (typeof allBookings !== "undefined") {
          allBookings = allBookings.filter(b => b.id !== docId);
        }
        const myCard = document.querySelector(`#my-card-${docId}`);
        if (myCard) myCard.remove();
        const adminCard = document.querySelector(`#card-${docId}`);
        if (adminCard) adminCard.remove();
      } catch (err) {
        console.error("Delete error:", err);
        alert("Could not delete. Please try again.");
      }
    }
  });
}

